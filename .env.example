# ── Required ──────────────────────────────────────────────────────────────────

# Your bot's token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Your bot's application/client ID
DISCORD_BOT_ID=your_bot_client_id_here

# ── Optional ──────────────────────────────────────────────────────────────────

# If set, slash commands are registered to this guild only (instant).
# Leave blank to register globally (up to 1 hour propagation).
GUILD_ID=your_guild_id_here

# Path to the SQLite database file (default: ./data/bot.sqlite)
# DB_PATH=./data/bot.sqlite

# Log level: debug | info | warn | error  (default: info)
# LOG_LEVEL=info
