# Copy this file to .env and fill in your values

# Your bot's token (from Discord Developer Portal → Bot → Token)
DISCORD_TOKEN=

# Your bot's application/client ID (from Discord Developer Portal → General Information)
DISCORD_BOT_ID=

# (Optional) Set to a specific guild ID to register commands instantly during development.
# Remove or leave blank to register commands globally (takes up to 1 hour to propagate).
GUILD_ID=
